{
  "scopeName": "source.qlang",
  "name": "QLang",
  "fileTypes": ["qlg"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.qlang", "match": "//.*$" },
        { "name": "comment.block.qlang", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.qlang",
      "begin": "\"",
      "end": "\"",
      "patterns": [{ "name": "constant.character.escape.qlang", "match": "\\\\." }]
    },
    "keywords": {
      "match": "\\b(if|else|while|for|return|break|continue|struct|new|try|catch|throw|using|namespace|printf|cout|print|sizeof|size|strlen|strcmp|strcpy|_gcd|parseInt|abort|true|false)\\b",
      "name": "keyword.control.qlang"
    },
    "types": {
      "match": "\\b(int|float|double|char|string|bool|void|stack|queue|vector|pair|priority_queue)\\b",
      "name": "storage.type.qlang"
    },
    "operators": {
      "match": "(->|\\.|::|\\+\\+|--|\\+=|-=|\\*=|/=|%=|&&|\\|\\||==|!=|>=|<=|>|<|\\+|\\-|\\*|/|%|!|&|\\*)",
      "name": "keyword.operator.qlang"
    },
    "numbers": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.qlang"
    },
    "identifiers": {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "name": "variable.other.qlang"
    }
  }
}