{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "/*", "close": "*/" },
    { "open": "/**", "close": " */", "notIn": ["string"] },
    { "open": "///", "close": "" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["/*", "*/"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(if|else|while|for|struct|try|catch|function|int\\s+main)\\b.*\\{[^}]*$",
    "decreaseIndentPattern": "^\\s*\\}"
  },
  "folding": {
    "markers": {
      "start": "^\\s*\\/\\/\\s*#region\\b",
      "end": "^\\s*\\/\\/\\s*#endregion\\b"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
  "onEnterRules": [
    {
      "beforeText": "^\\s*/\\*\\*$",
      "afterText": "",
      "action": {
        "indent": "indent",
        "appendText": " * "
      }
    },
    {
      "beforeText": "^\\s*/\\*\\*.*$",
      "afterText": "",
      "action": {
        "indent": "indent",
        "appendText": " * "
      }
    },
    {
      "beforeText": "^\\s*///\\s*@param\\s+.*$",
      "afterText": "",
      "action": {
        "indent": "indent",
        "appendText": "/// "
      }
    },
    {
      "beforeText": "^\\s*\\*\\s*@param\\s+.*$",
      "afterText": "",
      "action": {
        "indent": "indent",
        "appendText": " * "
      }
    },
    {
      "beforeText": "^\\s*\\*\\s*@return\\s+.*$",
      "afterText": "",
      "action": {
        "indent": "indent",
        "appendText": " * "
      }
    },
    {
      "beforeText": "^\\s*\\*\\s*@brief\\s+.*$",
      "afterText": "",
      "action": {
        "indent": "indent",
        "appendText": " * "
      }
    },
    {
      "beforeText": "^\\s*\\*\\s*@note\\s+.*$",
      "afterText": "",
      "action": {
        "indent": "indent",
        "appendText": " * "
      }
    },
    {
      "beforeText": "^\\s*\\*\\s*@see\\s+.*$",
      "afterText": "",
      "action": {
        "indent": "indent",
        "appendText": " * "
      }
    }
  ]
}